# ============================================
# AC System - 环境变量配置
# 复制此文件为 .env 并填入实际值：
#   cp env.example .env
# ============================================

# PostgreSQL 数据库密码（必填）
# docker-compose 使用该密码初始化数据库
DB_PASSWORD=your_strong_password_here

# JWT 签名密钥（必填）
# 用于生成和验证用户登录令牌
# 可使用 openssl rand -hex 32 生成
JWT_SECRET=your_jwt_secret_here

# 应用名称（可选，默认值：合同发票管理系统）
NEXT_PUBLIC_APP_NAME=合同发票管理系统
